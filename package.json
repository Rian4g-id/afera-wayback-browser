{
  "name": "afera-wayback-browser",
  "version": "1.0.0",
  "description": "Wayback Machine Browser - Check website history by Afera",
  "main": "main.js",
  "author": "Afera",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Rian4g-id/afera-wayback-browser.git"
  },
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:win": "electron-builder --win portable",
    "build:publish": "electron-builder --win --publish always"
  },
  "dependencies": {
    "electron-updater": "^6.8.3"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.afera.wayback-browser",
    "productName": "Afera Wayback Browser",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "styles.css",
      "renderer.js",
      "assets/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico",
      "publisherName": "Afera"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "publish": {
      "provider": "github",
      "owner": "Rian4g-id",
      "repo": "afera-wayback-browser",
      "releaseType": "release"
    }
  }
}
